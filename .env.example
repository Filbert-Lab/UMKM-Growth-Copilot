# ── Groq AI (Chat, Vision, Whisper) ───────────────────────────────────────
# Dapatkan API key di: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Model untuk chat/konsultasi bisnis
GROQ_MODEL=llama-3.1-8b-instant

# Model untuk transkripsi suara (Whisper)
GROQ_WHISPER_MODEL=whisper-large-v3
WHISPER_LANGUAGE=id

# ── Hugging Face (Image Generation) ───────────────────────────────────────
# Dapatkan API key di: https://huggingface.co/settings/tokens
HF_API_KEY=YOUR_HUGGING_FACE_API_KEY
HF_IMAGE_URL=https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell

# ── Cloudinary (Image Upload untuk Analisis Gambar) ───────────────────────
# Dapatkan credentials di: https://console.cloudinary.com
# Format CLOUDINARY_URL: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# ── Google Gemini (Analisis Dokumen PDF/DOCX/TXT) ─────────────────────────
# Dapatkan API key di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
